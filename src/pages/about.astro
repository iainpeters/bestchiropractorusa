---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About BestChiropractorUSA — Our Mission & Editorial Standards";
const description = "Learn about BestChiropractorUSA's mission to connect patients with verified, top-rated chiropractors across the United States.";
---
<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">About BestChiropractorUSA</h1>
    <div class="prose max-w-none text-gray-700">
      <p class="mb-4 leading-relaxed">BestChiropractorUSA is a comprehensive directory of verified chiropractors across the United States. Our mission is to help patients find qualified, top-rated chiropractic care by providing detailed, accurate practice profiles backed by verified credentials and real patient reviews.</p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8 mb-3">Our Editorial Standards</h2>
      <p class="mb-4 leading-relaxed">Every chiropractor in our directory has been reviewed by our editorial team. We verify active state licensure, confirm practice addresses and phone numbers, and evaluate patient reviews from Google and other trusted platforms. Each profile includes the doctor's credentials, office hours, specialties, services offered, accepted insurance information, and a professional bio.</p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8 mb-3">No Paid Placements</h2>
      <p class="mb-4 leading-relaxed">We do not accept paid placements or sponsored listings. Directory inclusion is earned through quality of care, patient satisfaction, and professional reputation. This ensures that every recommendation on our platform is based on merit, not advertising spend.</p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8 mb-3">How We Evaluate Chiropractors</h2>
      <p class="mb-4 leading-relaxed">Our evaluation process considers multiple factors:</p>
      <ul class="list-disc pl-6 space-y-2 mb-4">
        <li><strong>Credentials</strong> — Active Doctor of Chiropractic (DC) license and any additional certifications</li>
        <li><strong>Patient Reviews</strong> — Google ratings, review volume, and consistency of positive feedback</li>
        <li><strong>Practice Quality</strong> — Office environment, available services, and treatment philosophy</li>
        <li><strong>Accessibility</strong> — Office hours, location convenience, and appointment availability</li>
        <li><strong>Specializations</strong> — Advanced training in areas like pediatrics, prenatal care, sports medicine, or specific conditions</li>
      </ul>

      <h2 class="text-xl font-semibold text-gray-900 mt-8 mb-3">Keeping Information Current</h2>
      <p class="mb-4 leading-relaxed">We regularly update our profiles to ensure accuracy. If you notice outdated information about a practice in our directory, please contact us and we'll verify and update the listing promptly.</p>

      <h2 class="text-xl font-semibold text-gray-900 mt-8 mb-3">For Chiropractors</h2>
      <p class="mb-4 leading-relaxed">If you're a licensed chiropractor interested in being included in our directory, we welcome your inquiry. Our editorial team will review your practice based on our standard evaluation criteria.</p>

      <div class="mt-8 p-6 bg-blue-50 rounded-lg">
        <p class="text-gray-900 font-medium">Ready to find your chiropractor?</p>
        <p class="text-gray-600 mt-1">Browse our <a href="/" class="text-blue-600 hover:underline">verified directory</a> to find a top-rated chiropractor near you.</p>
      </div>
    </div>
  </div>
</BaseLayout>
