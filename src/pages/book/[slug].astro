---
import BaseLayout from '../../layouts/BaseLayout.astro';
import chiropractors from '../../data/chiropractors.json';

const chiros = chiropractors.filter(c => c.ghlFormId);

export function getStaticPaths() {
  return chiropractors.filter(c => c.ghlFormId).map(c => ({
    params: { slug: c.slug },
    props: { chiro: c }
  }));
}

const { chiro } = Astro.props;
const title = `Book Appointment - ${chiro.doctorName}, ${chiro.practiceName} | BestChiropractorUSA`;
---
<BaseLayout title={title} description={`Book an appointment with ${chiro.doctorName} at ${chiro.practiceName} in ${chiro.city}, ${chiro.state}.`}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <nav class="text-xs text-gray-500 mb-8">
      <a class="hover:text-gray-900" href="/">Home</a>
      <span class="mx-2">/</span>
      <a class="hover:text-gray-900" href={`/chiropractor/${chiro.slug}`}>{chiro.doctorName}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">Book Appointment</span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Book an Appointment</h1>
    <p class="text-gray-600 mb-8">{chiro.doctorName} at {chiro.practiceName} — {chiro.city}, {chiro.state}</p>
    <div class="bg-white rounded-lg border border-gray-200 p-2">
      <iframe
        src={`https://api.leadconnectorhq.com/widget/form/${chiro.ghlFormId}`}
        style="width:100%;border:none;min-height:600px;"
        scrolling="no"
        title={`Book appointment with ${chiro.doctorName}`}
      ></iframe>
    </div>
    <p class="text-xs text-gray-500 mt-4 text-center">
      <a href={`/chiropractor/${chiro.slug}`} class="text-blue-600 hover:underline">← Back to {chiro.doctorName}'s profile</a>
    </p>
  </div>
</BaseLayout>
