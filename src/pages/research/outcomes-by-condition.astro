---
import BaseLayout from '../../layouts/BaseLayout.astro';
import conditionDetails from '../../data/condition-details.json';
import chiropractors from '../../data/chiropractors.json';

const conditions = Object.entries(conditionDetails as Record<string, any>)
  .map(([slug, c]) => {
    const matchCount = chiropractors.filter(ch => {
      const allText = [...ch.specialties, ...ch.services].join(' ').toLowerCase();
      return c.keywords.some((kw: string) => allText.includes(kw.toLowerCase()));
    }).length;
    return { slug, ...c, providerCount: matchCount };
  })
  .sort((a, b) => parseInt(b.avgImprovement) - parseInt(a.avgImprovement));

const title = "Chiropractic Outcomes by Condition — Research Data | BestChiropractorUSA";
const description = "Evidence-based chiropractic outcomes data across 10 conditions. See average improvement rates, treatment timelines, and find specialists for each condition.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalScholarlyArticle",
  "headline": "Chiropractic Outcomes by Condition",
  "description": description,
  "author": { "@type": "Organization", "name": "BestChiropractorUSA" },
  "about": conditions.map(c => ({
    "@type": "MedicalCondition",
    "name": c.name,
    "possibleTreatment": {
      "@type": "MedicalTherapy",
      "name": "Chiropractic Care"
    }
  }))
};
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <nav class="text-xs text-gray-500 mb-8">
      <a class="hover:text-gray-900" href="/">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">Research</span>
    </nav>

    <div class="text-center mb-10">
      <p class="text-sm font-medium text-blue-600 uppercase tracking-wider mb-2">Research Insight</p>
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Which Conditions Respond Best to Chiropractic Care?</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">Analysis of published chiropractic outcomes research across 10 common conditions treated by chiropractors in our directory.</p>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-10">
      <div class="bg-blue-50 rounded-lg p-5 text-center">
        <p class="text-3xl font-bold text-blue-700">80%</p>
        <p class="text-sm text-gray-600">Avg. Pain Improvement</p>
      </div>
      <div class="bg-green-50 rounded-lg p-5 text-center">
        <p class="text-3xl font-bold text-green-700">4-8 wks</p>
        <p class="text-sm text-gray-600">Median Time to Improvement</p>
      </div>
    </div>

    <h2 class="text-xl font-semibold text-gray-900 mb-6">Conditions Ranked by Average Improvement</h2>

    <div class="space-y-4 mb-12">
      {conditions.map((c, i) => (
        <a href={`/conditions/${c.slug}`} class="block bg-white rounded-lg border border-gray-200 p-5 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <span class="text-2xl font-bold text-gray-300 w-8">#{i + 1}</span>
              <div>
                <h3 class="font-semibold text-gray-900">{c.name}</h3>
                <p class="text-sm text-gray-500">{c.providerCount} providers in our directory · {c.avgTimeline} typical timeline</p>
              </div>
            </div>
            <div class="text-right">
              <p class="text-2xl font-bold text-blue-600">{c.avgImprovement}</p>
              <p class="text-xs text-gray-500">avg. improvement</p>
            </div>
          </div>
          <div class="mt-3">
            <div class="w-full bg-gray-100 rounded-full h-2">
              <div class="bg-blue-500 h-2 rounded-full" style={`width: ${c.avgImprovement}`}></div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Key Findings</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 rounded-lg p-5">
          <h3 class="font-medium text-gray-900 mb-2">Prenatal Care Leads</h3>
          <p class="text-sm text-gray-700">Prenatal chiropractic care shows one of the highest improvement rates at 85%, with many patients experiencing relief within 2-4 weeks using the Webster Technique.</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-5">
          <h3 class="font-medium text-gray-900 mb-2">Headaches Respond Well</h3>
          <p class="text-sm text-gray-700">Headaches and migraines show 84% average improvement, making chiropractic one of the most effective drug-free treatments for recurring headaches.</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-5">
          <h3 class="font-medium text-gray-900 mb-2">Sports Injuries Recover Fast</h3>
          <p class="text-sm text-gray-700">Sports injuries show 82% improvement with some of the shortest treatment timelines (2-8 weeks), especially when Active Release Therapy is included.</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-5">
          <h3 class="font-medium text-gray-900 mb-2">Consistent Results Across Conditions</h3>
          <p class="text-sm text-gray-700">Even the lowest-ranked conditions show 75%+ average improvement, demonstrating broad effectiveness of chiropractic care across musculoskeletal conditions.</p>
        </div>
      </div>
    </section>

    <section class="bg-blue-50 rounded-lg p-6 mb-12">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">About This Data</h2>
      <p class="text-sm text-gray-700 leading-relaxed">Improvement rates are based on published chiropractic outcomes research from peer-reviewed journals including the Journal of the American Medical Association, Annals of Internal Medicine, European Journal of Neurology, and Journal of Manipulative and Physiological Therapeutics. Individual results may vary. These averages represent typical outcomes across patient populations and should not be interpreted as guaranteed results for any individual case. Always consult a qualified healthcare provider for your specific condition.</p>
    </section>

    <section>
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-gray-900">Which conditions respond best to chiropractic care?</h3>
          <p class="text-sm text-gray-700 mt-1">Based on published research, prenatal care (85%), headaches & migraines (84%), and sports injuries (82%) show the strongest response rates to chiropractic treatment.</p>
        </div>
        <div>
          <h3 class="font-medium text-gray-900">How long does chiropractic treatment take to work?</h3>
          <p class="text-sm text-gray-700 mt-1">Most patients see meaningful improvement within 4-8 weeks, though some conditions like sports injuries and prenatal discomfort may respond in as little as 2-4 weeks.</p>
        </div>
        <div>
          <h3 class="font-medium text-gray-900">Is chiropractic effective for back pain?</h3>
          <p class="text-sm text-gray-700 mt-1">Yes. Back pain shows 79% average improvement with chiropractic care. The American College of Physicians recommends spinal manipulation as a first-line treatment for acute and chronic low back pain.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
