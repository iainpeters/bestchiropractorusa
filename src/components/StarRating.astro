---
interface Props {
  rating: number | null;
  reviewCount: number | null;
}
const { rating, reviewCount } = Astro.props;
---
{rating && (
  <div class="flex items-center gap-1.5">
    <div class="flex items-center gap-0.5">
      {[1,2,3,4,5].map(i => (
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill={i <= Math.round(rating) ? "#facc15" : "none"}
          stroke="#facc15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/>
        </svg>
      ))}
    </div>
    <span class="text-sm font-medium text-gray-700">{rating}</span>
    {reviewCount && <span class="text-sm text-gray-500">({reviewCount})</span>}
  </div>
)}
