---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  jsonLd?: object | object[];
}

const { title, description = "Find verified chiropractors across the United States. Compare ratings, specialties, and book appointments.", canonicalUrl, jsonLd } = Astro.props;
const canonical = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content="https://bestchiropractorusa.com/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map(ld => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}
</head>
<body class="min-h-screen bg-gray-50 text-gray-900">
  <header class="sticky top-0 z-50 border-b border-gray-200 bg-gray-900/95 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a class="text-sm font-bold text-white uppercase tracking-wider" href="/">BestChiropractorUSA</a>
      <nav class="flex items-center gap-4 sm:gap-6">
        <a class="text-sm text-gray-300 hover:text-white transition-colors" href="/conditions/back-pain">Conditions</a>
        <a class="text-sm text-gray-300 hover:text-white transition-colors" href="/blog/what-does-a-chiropractor-do">Blog</a>
        <a class="text-sm text-gray-300 hover:text-white transition-colors" href="/about">About</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="border-t border-gray-200 bg-gray-900 text-gray-400 mt-16">
    <div class="max-w-6xl mx-auto px-4 py-8 text-center text-sm">
      <p>&copy; {new Date().getFullYear()} BestChiropractorUSA. All rights reserved.</p>
      <p class="mt-2">The trusted directory for finding licensed, verified chiropractors across the United States.</p>
    </div>
  </footer>
</body>
</html>
